# =============================================================================
# SIM Dampingan — Environment VPS production
# Akses awal: http://101.32.253.13:8080
# Nginx host + SSL nanti tetap pakai 80/443 dan proxy ke 8080
#
# Di VPS:
#   cp .env.vps.example .env
#   nano .env   → isi APP_KEY, DB_PASSWORD, DB_ROOT_PASSWORD
#   chmod +x docker/scripts/vps-first-deploy.sh
#   sudo ./docker/scripts/vps-first-deploy.sh
# =============================================================================

VPS_PUBLIC_IP=101.32.253.13
APP_PORT=8080

# --- Image (deploy manual: kosongkan = build lokal di VPS) ---
# BACKEND_IMAGE=ghcr.io/USERNAME/REPO/backend:latest
# NGINX_IMAGE=ghcr.io/USERNAME/REPO/nginx:latest

# --- Laravel ---
APP_NAME="SIM Dampingan"
APP_ENV=production
APP_KEY=base64:GANTI_DENGAN_php_artisan_key_generate
APP_DEBUG=false
APP_URL=http://101.32.253.13:8080

FRONTEND_URL=http://101.32.253.13:8080

LOG_CHANNEL=stack
LOG_LEVEL=error

# --- Database ---
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=SIM_Dampingan
DB_USERNAME=mentora
DB_PASSWORD=GANTI_PASSWORD_KUAT
DB_ROOT_PASSWORD=GANTI_ROOT_PASSWORD_KUAT

SESSION_DRIVER=database
SESSION_LIFETIME=120
CACHE_STORE=database
QUEUE_CONNECTION=database

FILESYSTEM_DISK=public

VITE_API_URL=/api
VITE_SUPERADMIN_WA=081234567890

# =============================================================================
# Firewall cloud (Tencent): cukup buka 22, 80, 443 — 8080 cukup lokal di VPS
#   sudo ufw allow 80/tcp
#   sudo ufw allow 443/tcp
#
# Buka: http://101.32.253.13:8080
# Seed: sudo docker compose exec backend php artisan db:seed
# =============================================================================
