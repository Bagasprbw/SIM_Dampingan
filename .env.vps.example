# =============================================================================
# SIM Dampingan — Environment VPS (akses via IP publik, tanpa domain)
# Di server VPS:
#   cp .env.vps.example .env
#   nano .env   → isi APP_KEY, DB_PASSWORD, DB_ROOT_PASSWORD
#   docker compose up -d --build
# =============================================================================

# IP publik VPS + port yang dibuka di firewall
VPS_PUBLIC_IP=101.32.253.13
APP_PORT=8080

# --- Image (deploy manual: kosongkan = build lokal di VPS) ---
# Setelah CI/CD GHCR aktif, uncomment:
# BACKEND_IMAGE=ghcr.io/USERNAME/REPO/backend:latest
# NGINX_IMAGE=ghcr.io/USERNAME/REPO/nginx:latest

# --- Laravel ---
APP_NAME="SIM Dampingan"
APP_ENV=production
APP_KEY=base64:GANTI_DENGAN_php_artisan_key_generate
APP_DEBUG=false
APP_URL=http://101.32.253.13:8080

# QR code profil anggota & link absolut
FRONTEND_URL=http://101.32.253.13:8080

LOG_CHANNEL=stack
LOG_LEVEL=error

# --- Database (host = service docker `db`) ---
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=SIM_Dampingan
DB_USERNAME=sim_user
DB_PASSWORD=GANTI_PASSWORD_KUAT
DB_ROOT_PASSWORD=GANTI_ROOT_PASSWORD_KUAT

# --- Session & cache ---
SESSION_DRIVER=database
SESSION_LIFETIME=120
CACHE_STORE=database
QUEUE_CONNECTION=database

FILESYSTEM_DISK=public

# Relatif — API otomatis ke http://IP:PORT/api (tidak perlu rebuild saat IP/port sama)
VITE_API_URL=/api
VITE_SUPERADMIN_WA=081234567890

# =============================================================================
# Setelah .env siap:
#   docker compose up -d --build
#   docker compose exec backend php artisan db:seed
#
# Buka: http://101.32.253.13:8080
#
# Firewall VPS (contoh Ubuntu):
#   sudo ufw allow 8080/tcp
#   sudo ufw enable
# =============================================================================
