# =============================================================================
# SIM Dampingan — Environment Docker (copy ke .env di root repo)
# cp .env.docker.example .env
# =============================================================================

# --- Port expose ke host (arahkan domain/nginx host ke port ini) ---
APP_PORT=8080

# --- Image tag (local dev kosongkan, production isi dari GHCR) ---
# NGINX_IMAGE=ghcr.io/USERNAME/sim-dampingan-nginx:latest
# BACKEND_IMAGE=ghcr.io/USERNAME/sim-dampingan-backend:latest

# --- Laravel ---
APP_NAME="SIM Dampingan"
APP_ENV=production
APP_KEY=base64:GANTI_DENGAN_php_artisan_key_generate
APP_DEBUG=false
APP_URL=https://domain-kamu.com

# URL frontend untuk QR code profil anggota
FRONTEND_URL=https://domain-kamu.com

LOG_CHANNEL=stack
LOG_LEVEL=error

# --- Database (host = nama service docker `db`) ---
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=SIM_Dampingan
DB_USERNAME=sim_user
DB_PASSWORD=GANTI_PASSWORD_KUAT
DB_ROOT_PASSWORD=GANTI_ROOT_PASSWORD_KUAT

# --- Session & cache ---
SESSION_DRIVER=database
SESSION_LIFETIME=120
CACHE_STORE=database
QUEUE_CONNECTION=database

FILESYSTEM_DISK=public

# --- Frontend build args (wajib saat docker compose build) ---
# Disarankan relatif agar ganti domain/subdomain tidak perlu rebuild image
VITE_API_URL=/api
VITE_SUPERADMIN_WA=081234567890

# =============================================================================
# CATATAN PENTING
# =============================================================================
# 1. JANGAN jalankan `docker compose down -v` di server — volume db_data terhapus!
# 2. Seed manual sekali: docker compose exec backend php artisan db:seed
# 3. Domain + HTTPS: arahkan nginx host ke localhost:APP_PORT (reverse proxy)
# 4. Backup DB: docker/scripts/backup-db.sh
#
# --- GitHub Actions (setelah VPS siap) ---
# Repository Variables: ENABLE_DEPLOY=true
# Repository Secrets:
#   SSH_HOST, SSH_USER, SSH_PRIVATE_KEY, DEPLOY_PATH (/opt/sim-dampingan)
#   VITE_API_URL, VITE_SUPERADMIN_WA
# Server .env production tambahkan:
#   BACKEND_IMAGE=ghcr.io/USERNAME/REPO/backend:latest
#   NGINX_IMAGE=ghcr.io/USERNAME/REPO/nginx:latest
#
# --- Nginx host (SSL) ---
# Lihat: docker/nginx/host-reverse-proxy.example.conf
